# ── 后端选择 ──────────────────────────────────────────────────
# 可选值: local | feishu | google_sheets
OUTPUT_BACKEND=local

# ── 本地 Excel 配置（OUTPUT_BACKEND=local 时生效）────────────
LOCAL_WORKBOOK_PATH=tao_config.xlsx

# ── TEC AI Gateway 配置 ────────────────────────────────────────
TEC_CHI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://ai-gateway.tec-do.cn/claw-agents/text/v1

# ── 飞书配置（OUTPUT_BACKEND=feishu 时生效）──────────────────
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET
FEISHU_BASE_ID=YOUR_FEISHU_BITABLE_BASE_ID

# ── Google Sheets 配置（OUTPUT_BACKEND=google_sheets 时生效）─
GOOGLE_CREDENTIALS_FILE=YOUR_SERVICE_ACCOUNT_JSON_PATH
GOOGLE_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
