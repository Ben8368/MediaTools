# MediaTools 环境变量配置示例
# 复制本文件为 .env 并填写实际值

# ── LLM API（字幕分析功能，可兼容 OpenAI 接口的服务）──
TEC_CHI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://ai-gateway.tec-do.cn/claw-agents/text/v1
ANALYSIS_MODEL=qwen3.6-plus

# ── 媒体输出目录 ──
MEDIA_OUTPUT_DIR=./downloads
MEDIA_NAMING_TEMPLATE={index}_{title}_{upload_date}

# ── capcut-mate 服务地址 ──
CAPCUT_MATE_BASE_URL=http://localhost:30000

# ── GUI 服务配置 ──
GUI_SERVER_NAME=127.0.0.1
GUI_SERVER_PORT=7860
GUI_SHARE=false

# ── API 安全配置（可选，留空则不启用认证）──
API_SECRET_KEY=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:7860,http://localhost:7860,http://127.0.0.1:5173,http://localhost:5173
PREVIEW_MAX_BYTES=26214400
ASSET_SCAN_MAX_FILES=5000
WORKSPACE_ALLOWED_ROOTS=./projects
